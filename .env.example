# Copy this file to .env and fill in your values.
# If ANTHROPIC_API_KEY is left blank, the app runs in DEMO_MODE (no API calls needed).

# --- LLM ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- Database ---
# Leave blank to use the default fmcg.db in the project root.
DB_BACKEND=sqlite
SQLITE_PATH=

# --- App ---
LOG_LEVEL=INFO
MAX_QUERY_ROWS=500
